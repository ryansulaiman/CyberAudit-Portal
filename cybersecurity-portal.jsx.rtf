\
  const handleFile = async (e) => \{\
    const f = e.target.files[0]; if (!f) return;\
    setErr(""); setPreview([]);\
    try \{\
      const text = await f.text();\
      const lines = text.split(/\\r?\\n/).filter(l => l.trim());\
      const headers = lines[0].split(",").map(h => h.trim().toLowerCase());\
