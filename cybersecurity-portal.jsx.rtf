        <Btn th=\{th\} variant="secondary" style=\{\{ fontSize: 12 \}\} onClick=\{() => \{\
          const csv = "name,email,department,password\\nJohn Doe,john@company.com,Engineering,pass123\\nJane Smith,jane@company.com,Marketing,pass123";\
