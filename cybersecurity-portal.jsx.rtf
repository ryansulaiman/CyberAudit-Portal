// ADMIN DASHBOARD\
// \uc0\u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \u9552 \
\
function AdminDashboard(\{ user, users, setUsers, audits, setAudits, tasks, setTasks, activity, setActivity, notifications, setNotifications, th \}) \{\
  const [tab, setTab] = useState("overview");\
  const [search, setSearch] = useState("");\
  const [filterDept, setFilterDept] = useState("All");\
  const [filterRisk, setFilterRisk] = useState("All");\
